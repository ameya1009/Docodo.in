generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(uuid())
  email            String     @unique
  name             String?
  subscriptionTier String     @default("FREE")
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  leads            Lead[]
  campaigns        Campaign[]
  chatbots         Chatbot[]
}

model Lead {
  id          String   @id @default(uuid())
  name        String
  email       String
  company     String?
  status      String   @default("New")
  aiScore     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assignedTo  User?    @relation(fields: [userId], references: [id])
  userId      String?
}

model Campaign {
  id          String   @id @default(uuid())
  name        String
  subject     String?
  content     String?
  status      String   @default("Draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User?    @relation(fields: [userId], references: [id])
  userId      String?
}

model Chatbot {
  id          String   @id @default(uuid())
  name        String
  themeColor  String   @default("#2bd4ac")
  welcomeMsg  String   @default("Hello! How can I help you today?")
  status      String   @default("Draft")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  owner       User?    @relation(fields: [userId], references: [id])
  userId      String?
}
